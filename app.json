{
  "expo": {
    "name": "勤怠管理",
    "slug": "timecard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "timecard",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.timecard.app"
    },
    "android": {
      "package": "com.timecard.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "baseUrl": "/Work-Time-Calc",
      "themeColor": "#2563EB",
      "backgroundColor": "#2563EB",
      "display": "standalone",
      "orientation": "portrait",
      "shortName": "勤怠管理",
      "description": "出退勤・給料かんたん管理アプリ"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://fig-jp.github.io"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
