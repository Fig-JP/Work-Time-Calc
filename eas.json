{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "key": "timecard-preview-v1",
        "paths": [
          "~/.gradle/caches",
          "~/.gradle/wrapper"
        ]
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "cache": {
        "key": "timecard-prod-v1",
        "paths": [
          "~/.gradle/caches",
          "~/.gradle/wrapper"
        ]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
